# EC2 A — Spring Boot (GHCR pull, 원격 MySQL)
# cp .env.example .env 후 값 설정. 실제 .env는 Git 커밋 금지.

# EC2 B private IP (같은 VPC). public IP는 dev 임시 점검용만.
MYSQL_HOST=10.0.1.20
MYSQL_PORT=3306
MYSQL_DATABASE=tripfit

# DB 계정 — 서버에서 export 또는 GitHub Secrets (CI/CD)
SPRING_DATASOURCE_USERNAME=tripfit_app
SPRING_DATASOURCE_PASSWORD=change-me-strong-password

APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# GHCR (private 패키지)
GHCR_IMAGE=ghcr.io/<github-owner>/tripfit-server:latest
# 수동 배포 시:
#   export GHCR_USERNAME=<GitHub 사용자>
#   export GHCR_PAT=<classic PAT, read:packages>
# CI/CD: GitHub Secrets GHCR_PAT, GHCR_USERNAME
