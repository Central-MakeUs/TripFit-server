# EC2 B private IP (같은 VPC). public IP는 dev 임시용만.
MYSQL_HOST=172.31.37.134
MYSQL_PORT=3306
MYSQL_DATABASE=tripfit

# root 대신 app 전용 계정 권장 (아래 가이드 참고)
SPRING_DATASOURCE_USERNAME=tripfit_app
SPRING_DATASOURCE_PASSWORD=change-me-app-password

APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# GHCR — CD(main push) 또는 scripts/ec2-deploy-app.sh 사용 시
# 형식: ghcr.io/<github-owner-lowercase>/tripfit-server:latest
GHCR_IMAGE=ghcr.io/central-makeus/tripfit-server:latest
