# MySQL
MYSQL_ROOT_PASSWORD=tripfit
MYSQL_DATABASE=tripfit
MYSQL_PORT=3306

# Spring Boot app (단일 EC2 / 로컬 compose — MYSQL_HOST=mysql 기본)
APP_PORT=8080
MYSQL_HOST=mysql
MYSQL_PORT=3306
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=tripfit

# EC2 2대 분리 시: deploy/README.md, deploy/app/.env.example, deploy/mysql/.env.example
# CI/CD: .github/workflows/ci-cd.yml — PR은 test만, main push는 test → GHCR → EC2 A deploy
# 가이드: docs/architecture/ec2-split-deployment.md
# - 로컬 compose: SPRING_PROFILES_ACTIVE=dev (ddl-auto: update, flyway: off)
# - Verify (로컬): ./scripts/verify-deploy.sh
# - Verify (EC2 A 분리): ./scripts/verify-deploy-app.sh
# - DB reset (dev only): docker compose down -v && docker compose up -d --build
#
# 3단계(운영) 전환 시:
# - SPRING_PROFILES_ACTIVE=prod in docker-compose
# - VERIFY_FLYWAY=true ./scripts/verify-deploy.sh
