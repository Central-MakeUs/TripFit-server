#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# src/가 stage에 없으면 Spotless 생략 — build.gradle·docs 등 인프라-only 커밋 보호
staged_src="$(git diff --cached --name-only -- 'src/')"
if [ -z "$staged_src" ]; then
	exit 0
fi

./gradlew spotlessApply -q

# git add -u src/는 src/ 전체의 수정 파일을 쓸어담아 partial commit(git commit --only -- <path>)에
# 관련 없는 파일까지 딸려 들어가게 함 — 원래 스테이징했던 파일만 다시 add
printf '%s\n' "$staged_src" | git add --pathspec-from-file=-
